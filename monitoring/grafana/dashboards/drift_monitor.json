{
  "title": "Churn Model — Drift Monitor",
  "uid": "churn-drift-monitor",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "Feature PSI (drift score)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "targets": [{ "expr": "feature_drift_psi", "legendFormat": "{{feature}}" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.2, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Critical Drift Flag",
      "type": "stat",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "targets": [{ "expr": "drift_critical" }]
    }
  ]
}
